# ============================================
# FlowCRM — Variáveis de Ambiente
# ============================================
# Copie este arquivo como .env e preencha os valores

# Supabase (obrigatórias — preenchidas automaticamente pelo Lovable Cloud)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=your-project-id

# Edge Functions (configurar em Supabase Secrets)
# ANTHROPIC_API_KEY=sk-ant-...          # Para AI Copilot
# GOOGLE_CLIENT_ID=...                  # Para Google Calendar
# GOOGLE_CLIENT_SECRET=...              # Para Google Calendar
# SLACK_BOT_TOKEN=xoxb-...              # Para notificações Slack
# EVOLUTION_API_URL=https://...         # Para WhatsApp
# EVOLUTION_API_KEY=...                 # Para WhatsApp
# SENTRY_DSN=https://...@sentry.io/... # Para monitoramento de erros
